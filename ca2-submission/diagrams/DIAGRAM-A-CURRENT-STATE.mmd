graph TB
    subgraph external["🌐 EXTERNAL (Internet)"]
        client["Client Browser/API"]
    end
    
    subgraph boundary1["🔓 TRUST BOUNDARY 1: Kubernetes External Entry"]
        ingress["Traefik Ingress<br/>gateway.local:8080<br/>(KEDA HTTP Proxy)<br/>❌ No Auth Required"]
    end
    
    subgraph cluster["🔒 TRUST BOUNDARY 2: Kubernetes Cluster (ca2 namespace)<br/>❌ No Network Policy - Any pod can reach any pod"]
        subgraph services["Microservices"]
            gateway["🔴 GATEWAY Pod<br/>Port: 5000<br/>Issues:<br/>- Runs as ROOT<br/>- No auth validation<br/>- No resource limits<br/>- No logging"]
            checkout["🔴 CHECKOUT Pod<br/>Port: 5001<br/>Issues:<br/>- Runs as ROOT<br/>- Calls pricing/inventory<br/>  with NO auth<br/>- No resource limits"]
            pricing["🔴 PRICING Pod<br/>Port: 5002<br/>Issues:<br/>- Runs as ROOT<br/>- No auth required<br/>- No resource limits"]
            inventory["🔴 INVENTORY Pod<br/>Port: 5003<br/>Issues:<br/>- Runs as ROOT<br/>- No auth required<br/>- No resource limits"]
        end
        
        subgraph data["Data Layer"]
            postgres["🔴 PostgreSQL Pod<br/>Port: 5432<br/>Issues:<br/>- Runs as ROOT<br/>- ❌ ACCESSIBLE FROM<br/>  ANY POD (no auth)<br/>- Credentials in plain<br/>  Kubernetes Secret"]
            pvc["Persistent Volume<br/>(1GB storage)"]
            secret["🔴 K8s Secret<br/>(postgres-secret)<br/>DB username/password<br/>❌ NOT ENCRYPTED<br/>at rest in etcd"]
        end
        
        subgraph scaling["Auto-Scaling"]
            keda["KEDA HTTPScaledObject<br/>Gateway: 0-5 replicas<br/>✅ Scale-to-zero working"]
        end
    end
    
    %% Data flows
    client -->|HTTP Request<br/>No encryption| ingress
    ingress -->|Routes to| gateway
    
    gateway -->|HTTP calls<br/>❌ NO AUTH| checkout
    gateway -->|HTTP calls<br/>❌ NO AUTH| pricing
    gateway -->|HTTP calls<br/>❌ NO AUTH| inventory
    
    checkout -->|HTTP POST<br/>❌ NO AUTH| pricing
    checkout -->|HTTP GET<br/>❌ NO AUTH| inventory
    
    checkout -->|SQL (NO AUTH)<br/>❌ ROOT ACCESS| postgres
    
    pricing -.->|SECURITY ISSUE<br/>Can access DB!| postgres
    inventory -.->|SECURITY ISSUE<br/>Can access DB!| postgres
    
    postgres -->|Stores data| pvc
    secret -.->|Credentials for| postgres
    keda -->|Manages replicas| gateway
    
    %% Styling
    classDef critical fill:#ff4444,stroke:#cc0000,stroke-width:3px,color:#fff
    classDef issue fill:#ffaa00,stroke:#ff6600,stroke-width:2px,color:#000
    classDef safe fill:#44aa44,stroke:#009900,stroke-width:2px,color:#fff
    classDef boundary fill:#ccccff,stroke:#0000ff,stroke-width:2px,color:#000
    classDef data fill:#ff9999,stroke:#ff0000,stroke-width:2px,color:#000
    
    class gateway,checkout,pricing,inventory,postgres critical
    class secret issue
    class keda safe
    class external,boundary1,cluster boundary
    class pvc data

